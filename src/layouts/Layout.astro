---
import "../styles/global.css";
import CustomCursor from "../components/CustomCursor.astro";
import AnimatedBackground from "../components/AnimatedBackground.astro";
import TerminalNav from "../components/TerminalNav.astro";
import AITerminal from "../components/AITerminal.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: "website" | "article";
}

const {
  title,
  description = "Frontend engineer especializado en Angular, accesibilidad real y tooling. Construyo cosas que luego tengo que mantener. Remoto.",
  image = "https://altaskur.dev/favicon-192.png",
  ogType = "website",
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, "https://altaskur.dev").href;
const ogImage = image.startsWith("http")
  ? image
  : `https://altaskur.dev${image}`;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="author" content="Isaac Julián Pavón Ruiz (altaskur)" />
    <meta
      name="keywords"
      content="Frontend Engineer, Angular Developer, TypeScript, Web Accessibility, WCAG, a11y, SSR, Astro, Ionic, Frontend Engineer remoto España, AI-assisted development, DevFest Alicante, Angular 19, Angular 20, Angular 21"
    />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="192x192" href="/favicon-192.png" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>
    <link
      rel="alternate"
      type="application/rss+xml"
      title="altaskur — blog"
      href="/rss.xml"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript
      ><link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
        rel="stylesheet"
      /></noscript
    >
  </head>
  <body
    class="bg-background text-gray-100 font-sans antialiased selection:bg-accent selection:text-white"
  >
    <!-- Skip to Content para accesibilidad -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[200] focus:bg-accent focus:text-black focus:px-4 focus:py-2 focus:rounded-lg focus:font-bold"
    >
      Ir al contenido principal
    </a>

    <div class="fixed inset-0 z-0 pointer-events-none">
      <AnimatedBackground />
    </div>

    <!-- Global Scroll Progress Bar -->
    <div
      class="fixed right-0 top-0 h-full w-1 bg-gray-900 z-50 hidden md:block"
    >
      <div
        id="scroll-progress"
        class="w-full bg-accent absolute top-0 left-0"
        style="height: 0%"
      >
      </div>
    </div>

    <TerminalNav />
    <AITerminal />
    <CustomCursor />
    <main id="main-content">
      <slot />
    </main>
    <script>
      import Lenis from "lenis";
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis();

      // Expose lenis to window for global control
      window.lenis = lenis;

      // Integrate Lenis with GSAP ScrollTrigger
      lenis.on("scroll", ScrollTrigger.update);

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });

      gsap.ticker.lagSmoothing(0);

      // Scroll Progress Logic (via Lenis scroll event)
      const progressBar = document.getElementById("scroll-progress");
      lenis.on("scroll", ({ progress }: { progress: number }) => {
        if (progressBar) progressBar.style.height = `${progress * 100}%`;
      });
    </script>
  </body>
</html>
