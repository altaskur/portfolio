---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const typeLabels: Record<string, string> = {
  article: "artículo",
  experiment: "experimento",
};

const getProxyImage = (url: string) =>
  `https://wsrv.nl/?url=${encodeURIComponent(url)}&w=800&q=80`;

// Local posts
const localPosts = await getCollection("blog", ({ data }) => !data.draft);
const localArticles = localPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .map((post) => ({
    title: post.data.title,
    description: post.data.description,
    url: `/blog/${post.id.replace(/\.(md|mdx)$/, "")}`,
    publishDate: post.data.publishDate.toISOString(),
    label: typeLabels[post.data.type] ?? post.data.type,
    coverImage: post.data.coverImage ?? null,
    source: "local" as const,
  }));

// Dev.to posts
let devtoArticles: {
  title: string;
  description: string;
  url: string;
  publishDate: string;
  label: string;
  coverImage: string | null;
  source: "devto";
}[] = [];

try {
  const res = await fetch(
    "https://dev.to/api/articles?username=altaskur&per_page=30",
  );
  if (res.ok) {
    const data = await res.json();
    devtoArticles = data.map((a: any) => ({
      title: a.title,
      description: a.description ?? "",
      url: a.url,
      publishDate: a.published_at,
      label: a.tag_list?.[0] ?? "artículo",
      coverImage: a.cover_image ?? null,
      source: "devto" as const,
    }));
  }
} catch {
  console.warn("[Blog] Dev.to API unavailable at build time");
}

const allPosts = [...localArticles, ...devtoArticles].sort(
  (a, b) =>
    new Date(b.publishDate).valueOf() - new Date(a.publishDate).valueOf(),
);

const total = allPosts.length;
const localCount = localArticles.length;
const devtoCount = devtoArticles.length;
---

<Layout title="Blog | altaskur">
  <main class="min-h-screen px-4 py-12 md:py-20 md:px-10 max-w-5xl mx-auto">
    <header class="mb-10 md:mb-16">
      <div class="flex items-start justify-between gap-4 flex-wrap mb-4">
        <h1 class="text-3xl font-bold text-white md:text-4xl lg:text-6xl">
          <span class="text-accent">></span> El blog
        </h1>
        <div class="flex items-center gap-3 mt-2 md:mt-4 self-end">
          <span class="font-mono text-xs text-gray-600">{total} entradas</span>
          <a
            href="/rss.xml"
            title="Suscribirse por RSS"
            aria-label="Feed RSS del blog"
            class="inline-flex items-center gap-1.5 font-mono text-xs text-orange-400/60 hover:text-orange-400 transition-colors"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <circle cx="6" cy="18" r="2"/>
              <path d="M6 14a8 8 0 0 1 8 8h2a10 10 0 0 0-10-10v2z"/>
              <path d="M6 10a12 12 0 0 1 12 12h2A14 14 0 0 0 6 8v2z"/>
            </svg>
            RSS
          </a>
        </div>
      </div>
      <p class="text-base md:text-xl text-gray-400 max-w-2xl">
        Notas técnicas, experimentos y reflexiones sobre arquitectura frontend,
        rendimiento y sistemas propios.
      </p>
    </header>

    <!-- Filtros por fuente -->
    <div class="flex gap-3 mb-10 overflow-x-auto pb-2 scrollbar-none" role="tablist" aria-label="Filtrar artículos">
      <button
        data-filter="all"
        role="tab"
        aria-selected="true"
        class="filter-btn active px-4 py-2 rounded-full font-mono text-sm font-bold whitespace-nowrap transition-colors bg-accent text-black border border-accent"
      >
        Todos <span class="opacity-60 font-normal">({total})</span>
      </button>
      <button
        data-filter="local"
        role="tab"
        aria-selected="false"
        class="filter-btn px-4 py-2 rounded-full font-mono text-sm whitespace-nowrap transition-colors bg-gray-900 border border-gray-800 text-gray-400 hover:border-accent hover:text-white"
      >
        altaskur.dev <span class="opacity-60">({localCount})</span>
      </button>
      <button
        data-filter="devto"
        role="tab"
        aria-selected="false"
        class="filter-btn px-4 py-2 rounded-full font-mono text-sm whitespace-nowrap transition-colors bg-gray-900 border border-gray-800 text-gray-400 hover:border-accent hover:text-white"
      >
        dev.to <span class="opacity-60">({devtoCount})</span>
      </button>
    </div>

    <!-- Lista de artículos -->
    <div id="posts-list" class="grid gap-4">
      {
        allPosts.map((post) => {
          const isLocal = post.source === "local";
          const extAttrs = !isLocal
            ? { target: "_blank", rel: "noopener noreferrer" }
            : {};
          const imgSrc = post.coverImage
            ? isLocal
              ? post.coverImage
              : getProxyImage(post.coverImage)
            : null;

          return (
            <article
              data-source={post.source}
              data-post-title={post.title}
              class="post-card group relative flex flex-col sm:flex-row gap-4 p-4 md:p-5 rounded-xl border border-gray-900 bg-gray-900/20 hover:border-gray-700 hover:bg-gray-900/40 transition-all duration-200"
            >
              {/* Imagen — solo si existe */}
              {imgSrc && (
                <a
                  href={post.url}
                  {...extAttrs}
                  class="relative sm:w-36 md:w-44 flex-shrink-0 aspect-video overflow-hidden rounded-lg bg-gray-900 border border-gray-800 block"
                  tabindex="-1"
                  aria-hidden="true"
                >
                  <img
                    src={imgSrc}
                    alt=""
                    class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </a>
              )}

              {/* Contenido */}
              <div class="flex flex-col justify-between gap-2 min-w-0 flex-1">
                <div class="space-y-1.5">
                  <div class="flex items-center gap-2 flex-wrap">
                    {isLocal ? (
                      <span class="inline-flex items-center gap-1 font-mono text-[10px] font-bold px-2 py-0.5 rounded bg-accent/10 text-accent border border-accent/30">
                        <span class="w-1 h-1 rounded-full bg-accent" />
                        altaskur.dev
                      </span>
                    ) : (
                      <span class="inline-flex items-center gap-1 font-mono text-[10px] font-bold px-2 py-0.5 rounded bg-indigo-500/10 text-indigo-400 border border-indigo-500/30">
                        <span class="w-1 h-1 rounded-full bg-indigo-400" />
                        dev.to
                      </span>
                    )}
                    <span class="font-mono text-[10px] text-gray-600 uppercase tracking-wider">
                      {post.label}
                    </span>
                  </div>

                  <h2 class="text-base md:text-lg font-bold text-white group-hover:text-accent transition-colors leading-snug">
                    <a href={post.url} {...extAttrs} class="block">
                      {post.title}
                    </a>
                  </h2>

                  {post.description && (
                    <p class="text-sm text-gray-400 leading-relaxed line-clamp-2">
                      {post.description}
                    </p>
                  )}
                </div>

                <div class="flex items-center justify-between gap-4 pt-1">
                  <span class="font-mono text-xs text-gray-600">
                    {new Date(post.publishDate).toLocaleDateString("es-ES", {
                      day: "numeric",
                      month: "short",
                      year: "numeric",
                    })}
                  </span>
                  <a
                    href={post.url}
                    {...extAttrs}
                    class="text-xs font-mono font-bold text-gray-500 hover:text-accent transition-colors flex items-center gap-1 shrink-0"
                  >
                    Leer
                    {!isLocal ? (
                      <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
                    ) : (
                      <span aria-hidden="true">→</span>
                    )}
                  </a>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>

    <!-- Cargar más -->
    <div id="load-more-wrap" class="mt-10 flex flex-col items-center gap-3">
      <button
        id="load-more-btn"
        class="font-mono text-sm text-gray-500 border border-gray-800 px-6 py-3 rounded-lg hover:border-accent hover:text-accent transition-all duration-300 hidden"
      >
        cargar más
      </button>
      <p id="posts-counter" class="font-mono text-xs text-gray-700"></p>
    </div>
  </main>
</Layout>

<script>
  const PAGE_SIZE = 8;
  let activeFilter = "all";
  let visibleCount = PAGE_SIZE;

  const cards = Array.from(
    document.querySelectorAll<HTMLElement>(".post-card"),
  );
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const loadMoreBtn = document.getElementById("load-more-btn") as HTMLButtonElement;
  const counter = document.getElementById("posts-counter");

  function getFiltered(): HTMLElement[] {
    if (activeFilter === "all") return cards;
    return cards.filter((c) => c.dataset.source === activeFilter);
  }

  function render() {
    const filtered = getFiltered();
    const total = filtered.length;

    // Hide all first
    cards.forEach((c) => {
      c.style.display = "none";
    });

    // Show up to visibleCount of filtered
    filtered.slice(0, visibleCount).forEach((c) => {
      c.style.display = "";
    });

    // Load more button
    if (visibleCount < total) {
      loadMoreBtn.classList.remove("hidden");
      loadMoreBtn.textContent = `cargar más`;
    } else {
      loadMoreBtn.classList.add("hidden");
    }

    // Counter
    if (counter) {
      const showing = Math.min(visibleCount, total);
      counter.textContent =
        total > 0 ? `mostrando ${showing} de ${total}` : "";
    }
  }

  // Filter buttons
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeFilter = btn.dataset.filter ?? "all";
      visibleCount = PAGE_SIZE;

      filterBtns.forEach((b) => {
        const isActive = b === btn;
        b.setAttribute("aria-selected", String(isActive));
        if (isActive) {
          b.classList.add("bg-accent", "text-black", "border-accent");
          b.classList.remove("bg-gray-900", "text-gray-400", "border-gray-800");
        } else {
          b.classList.remove("bg-accent", "text-black", "border-accent");
          b.classList.add("bg-gray-900", "text-gray-400", "border-gray-800");
        }
      });

      render();
    });
  });

  // Load more
  loadMoreBtn?.addEventListener("click", () => {
    visibleCount += PAGE_SIZE;
    render();
  });

  // Initial render
  render();

  // Tempoo: tracking de clicks en posts
  cards.forEach((card) => {
    const title = card.dataset.postTitle ?? "";
    const source = card.dataset.source ?? "";
    card.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        (window as any).tempoo?.track("blog_post_clicked", { title, source });
      });
    });
  });
</script>

<style>
  .scrollbar-none {
    scrollbar-width: none;
  }
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
