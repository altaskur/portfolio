---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const readingTime = Math.ceil((post.body?.split(/\s+/).length ?? 0) / 200);
const typeLabels: Record<string, string> = {
  article: "artículo",
  experiment: "experimento",
};

const allLocalPosts = await getCollection("blog", ({ data }) => !data.draft);
const relatedLocal = allLocalPosts
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 2)
  .map((p) => ({
    title: p.data.title,
    url: `/blog/${p.id.replace(/\.(md|mdx)$/, "")}`,
    date: p.data.publishDate.toLocaleDateString("es-ES", {
      month: "short",
      year: "numeric",
    }),
    source: "local" as const,
  }));

let relatedDevto: {
  title: string;
  url: string;
  date: string;
  source: "devto";
}[] = [];
try {
  const res = await fetch(
    "https://dev.to/api/articles?username=altaskur&per_page=4",
  );
  if (res.ok) {
    const data = await res.json();
    relatedDevto = data.slice(0, 4 - relatedLocal.length).map((a: any) => ({
      title: a.title,
      url: a.url,
      date: new Date(a.published_at).toLocaleDateString("es-ES", {
        month: "short",
        year: "numeric",
      }),
      source: "devto" as const,
    }));
  }
} catch {}

const relatedPosts = [...relatedLocal, ...relatedDevto].slice(0, 4);

const slug = post.id.replace(/\.(md|mdx)$/, "");
const coverImage = post.data.coverImage ?? null;
---

<Layout
  title={`${post.data.title} | altaskur`}
  description={post.data.description}
  image={`/og/${slug}.png`}
  ogType="article"
>
  <main class="min-h-screen px-4 pt-24 pb-12 md:pt-32 md:pb-20 md:px-10">
    <div class="max-w-6xl mx-auto w-full">
      <div class="blog-layout">
        <!-- Columna principal -->
        <div class="blog-main-col">
          <article>
            <header class="mb-8 md:mb-14">
              <div class="flex items-center gap-3 mb-6 md:mb-8 flex-wrap">
                <img
                  src="/assets/avatar.webp"
                  alt="altaskur"
                  class="w-10 h-10 rounded-full object-cover border border-gray-800"
                  width="40"
                  height="40"
                />
                <div>
                  <p class="text-sm font-medium text-white">altaskur</p>
                  <p class="text-xs text-gray-500 font-mono mt-0.5">
                    {
                      post.data.publishDate.toLocaleDateString("es-ES", {
                        day: "numeric",
                        month: "short",
                        year: "numeric",
                      })
                    }
                    &nbsp;·&nbsp; {readingTime} min lectura
                  </p>
                </div>
                <span
                  class="ml-auto inline-flex items-center gap-1.5 font-mono text-xs font-bold px-2.5 py-1 rounded-md bg-accent/10 text-accent border border-accent/30"
                >
                  <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
                  {typeLabels[post.data.type] ?? post.data.type}
                </span>
              </div>
              <h1
                class="text-2xl md:text-4xl lg:text-5xl font-bold text-white leading-tight mb-4 md:mb-5 break-words"
              >
                {post.data.title}
              </h1>
              <p
                class="text-base md:text-lg text-gray-400 leading-relaxed pb-6 md:pb-10"
              >
                {post.data.description}
              </p>
            </header>

            {
              coverImage && (
                <div class="relative w-full aspect-video overflow-hidden rounded-xl border border-gray-800 mb-10 md:mb-14 bg-gray-900">
                  <img
                    src={coverImage}
                    alt={post.data.title}
                    class="absolute inset-0 w-full h-full object-cover"
                    width="1200"
                    height="675"
                  />
                </div>
              )
            }

            <div class="prose-blog">
              <Content />
            </div>
          </article>

          <!-- Footer -->
          <footer
            class="mt-10 md:mt-20 pt-10 border-t border-gray-800 flex flex-col gap-10"
          >
            <!-- Autor -->
            <div
              class="flex gap-5 items-start bg-gray-900/50 border border-gray-800 rounded-xl p-6"
            >
              <img
                src="/assets/avatar.webp"
                alt="altaskur"
                class="w-14 h-14 rounded-full object-cover border-2 border-accent flex-shrink-0"
                width="56"
                height="56"
              />
              <div>
                <p class="text-base font-semibold text-white mb-0.5">
                  altaskur
                </p>
                <p class="text-xs font-mono text-accent mb-3">
                  altaskur.dev · @altaskur
                </p>
                <p class="text-sm text-gray-400 leading-relaxed">
                  Angular developer en proyectos enterprise. Arquitectura,
                  SSR y accesibilidad (WCAG 2.1/2.2). Remoto desde Alicante.
                </p>
                <div class="flex gap-2 mt-4 flex-wrap">
                  <a
                    href="https://github.com/altaskur"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs font-mono px-3 py-1.5 rounded border border-gray-700 text-gray-400 hover:border-accent hover:text-accent transition-all no-underline"
                  >
                    github ↗
                  </a>
                  <a
                    href="https://dev.to/altaskur"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs font-mono px-3 py-1.5 rounded border border-gray-700 text-gray-400 hover:border-accent hover:text-accent transition-all no-underline"
                  >
                    dev.to ↗
                  </a>
                  <a
                    href="https://linkedin.com/in/isaac-julián/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs font-mono px-3 py-1.5 rounded border border-gray-700 text-gray-400 hover:border-accent hover:text-accent transition-all no-underline"
                  >
                    linkedin ↗
                  </a>
                </div>
              </div>
            </div>

            <!-- Seguir leyendo -->
            {
              relatedPosts.length > 0 && (
                <div>
                  <p class="text-xs font-mono font-semibold text-gray-500 uppercase tracking-widest mb-5">
                    Seguir leyendo
                  </p>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    {relatedPosts.map((rp) => (
                      <a
                        href={rp.url}
                        {...(rp.source === "devto"
                          ? { target: "_blank", rel: "noopener noreferrer" }
                          : {})}
                        class="related-post-link group flex flex-col gap-2 bg-gray-900/50 border border-gray-800 rounded-lg p-4 no-underline hover:border-gray-700 transition-colors"
                      >
                        <span
                          class={`inline-flex items-center gap-1.5 text-[10px] font-mono font-semibold ${rp.source === "local" ? "text-accent" : "text-indigo-400"}`}
                        >
                          <span class="w-1 h-1 rounded-full bg-current" />
                          {rp.source === "local" ? "altaskur.dev" : "dev.to"}
                        </span>
                        <p class="related-post-title text-sm font-medium text-gray-200 leading-snug group-hover:text-accent transition-colors">
                          {rp.title}
                        </p>
                        <p class="text-[10px] font-mono text-gray-600">
                          {rp.date}
                        </p>
                      </a>
                    ))}
                  </div>
                </div>
              )
            }
          </footer>
        </div>

        <!-- TOC sidebar -->
        <aside
          id="toc-aside"
          class="hidden lg:block"
          aria-label="Tabla de contenidos"
        >
          <div id="toc-sticky" style="position:relative;will-change:transform">
            <div
              id="toc-progress-wrap"
              style="height:2px;background:#1f2937;border-radius:1px;margin-bottom:20px;overflow:hidden"
            >
              <div
                id="toc-progress"
                style="height:100%;width:0%;background:var(--color-accent);border-radius:1px;transition:width 0.1s linear"
              >
              </div>
            </div>
            <p
              style="font-size:9px;font-family:'JetBrains Mono',monospace;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.12em;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid #1f2937"
            >
              En este artículo
            </p>
            <ol
              id="toc-list"
              style="list-style:none;display:flex;flex-direction:column;gap:0"
            >
            </ol>
          </div>
        </aside>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Tempoo: tracking de clicks en posts relacionados
  document.querySelectorAll<HTMLAnchorElement>(".related-post-link").forEach((link) => {
    link.addEventListener("click", () => {
      (window as any).tempoo?.track("related_post_clicked", {
        from: window.location.pathname,
        to: link.getAttribute("href") ?? "",
        title: link.querySelector(".related-post-title")?.textContent ?? "",
      });
    });
  });

  // Tempoo: tracking de scroll del artículo (25 / 50 / 75 / 100%)
  const article = document.querySelector<HTMLElement>(".prose-blog");
  if (article) {
    const milestones = [25, 50, 75, 100];
    const reached = new Set<number>();
    const title = document.title.replace(" | altaskur", "").trim();

    const checkScroll = () => {
      const articleTop = article.getBoundingClientRect().top + window.scrollY;
      const articleH = article.offsetHeight;
      const scrolled = window.scrollY + window.innerHeight - articleTop;
      const pct = Math.round((scrolled / articleH) * 100);

      milestones.forEach((m) => {
        if (pct >= m && !reached.has(m)) {
          reached.add(m);
          (window as any).tempoo?.track("article_scroll_depth", {
            title,
            depth: m,
            url: window.location.pathname,
          });
        }
      });
    };

    const lenis = (window as any).lenis;
    if (lenis) {
      lenis.on("scroll", checkScroll);
    } else {
      window.addEventListener("scroll", checkScroll, { passive: true });
    }
    checkScroll();
  }

  const headings =
    document.querySelectorAll<HTMLHeadingElement>(".prose-blog h2");
  const tocList = document.getElementById("toc-list");

  if (headings.length && tocList) {
    headings.forEach((h, i) => {
      if (!h.id) h.id = `s${i}`;

      const li = document.createElement("li");
      li.dataset.target = h.id;
      li.style.cssText =
        "display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:1px solid #0d1117;cursor:pointer;transition:all .15s";

      const num = document.createElement("span");
      num.textContent = `0${i + 1}`;
      num.style.cssText =
        "font-size:9px;font-family:JetBrains Mono,monospace;color:#374151;flex-shrink:0;margin-top:2px;transition:color .15s;min-width:20px";

      const text = document.createElement("span");
      text.textContent = h.textContent ?? "";
      text.style.cssText =
        "font-size:12px;color:#6b7280;line-height:1.5;transition:color .15s";

      li.appendChild(num);
      li.appendChild(text);

      li.addEventListener("mouseenter", () => {
        if (!li.classList.contains("active")) text.style.color = "#d1d5db";
      });
      li.addEventListener("mouseleave", () => {
        if (!li.classList.contains("active")) text.style.color = "#6b7280";
      });

      li.addEventListener("click", () => {
        document
          .getElementById(h.id)
          ?.scrollIntoView({ behavior: "smooth", block: "start" });
      });

      tocList.appendChild(li);
    });

    const bar = document.getElementById("toc-progress");
    const items = Array.from(tocList.children) as HTMLElement[];
    const tocSticky = document.getElementById("toc-sticky");
    const tocAside = document.getElementById("toc-aside");
    const STICKY_TOP = 96; // 6rem in px

    const setActive = (activeId: string) => {
      items.forEach((li) => {
        const isActive = li.dataset.target === activeId;
        li.classList.toggle("active", isActive);
        const num = li.children[0] as HTMLElement;
        const txt = li.children[1] as HTMLElement;
        num.style.color = isActive ? "var(--color-accent)" : "#374151";
        txt.style.color = isActive ? "#e5e7eb" : "#6b7280";
        (txt as any).style.fontWeight = isActive ? "500" : "400";
      });
    };

    /**
     * Simulates position:sticky by manually translating the TOC element.
     * Required because Lenis v1 uses body transforms that break native sticky.
     */
    const positionTOC = (scrollY: number) => {
      if (!tocSticky || !tocAside) return;
      const asideTop = tocAside.offsetTop;
      const maxTranslate = Math.max(
        0,
        tocAside.offsetHeight - tocSticky.offsetHeight,
      );
      const translateY = Math.min(
        maxTranslate,
        Math.max(0, scrollY - asideTop + STICKY_TOP),
      );
      tocSticky.style.transform = `translateY(${translateY}px)`;
    };

    const onScroll = (scrollY: number) => {
      const total = document.body.scrollHeight - window.innerHeight;
      if (bar && total > 0)
        bar.style.width = `${Math.min(100, (scrollY / total) * 100)}%`;

      let activeId = headings[0]?.id ?? "";
      headings.forEach((h) => {
        if (scrollY + 140 >= (h as HTMLElement).offsetTop) activeId = h.id;
      });
      setActive(activeId);
      positionTOC(scrollY);
    };

    /**
     * Prefer Lenis scroll events (set on window.lenis by Layout.astro)
     * to get the correct virtual scroll position when Lenis is active.
     */
    const lenis = (window as any).lenis;
    if (lenis) {
      lenis.on("scroll", ({ scroll }: { scroll: number }) => onScroll(scroll));
    } else {
      window.addEventListener("scroll", () => onScroll(window.scrollY), {
        passive: true,
      });
    }
    onScroll(0);
  }
</script>

<style>
  .blog-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .blog-main-col {
    min-width: 0;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  @media (min-width: 1024px) {
    .blog-layout {
      grid-template-columns: 1fr 200px;
      gap: 5rem;
    }
    #toc-aside {
      align-self: stretch;
    }
  }
</style>
