---
import { getCollection } from 'astro:content';

const typeLabels: Record<string, string> = { article: 'artículo', experiment: 'experimento' };
const getProxyImage = (url: string) =>
    `https://wsrv.nl/?url=${encodeURIComponent(url)}&w=800&q=80`;

const localPosts = await getCollection('blog', ({ data }) => !data.draft);

const localArticles = localPosts.map(post => ({
    title: post.data.title,
    description: post.data.description,
    url: `/blog/${post.id.replace(/\.(md|mdx)$/, '')}`,
    published_at: post.data.publishDate.toISOString(),
    tag_list: [typeLabels[post.data.type] ?? post.data.type],
    cover_image: post.data.coverImage ?? null,
    source: 'local' as const,
}));

let devtoArticles: {
    title: string;
    description: string;
    url: string;
    published_at: string;
    tag_list: string[];
    cover_image: string | null;
    source: 'devto';
}[] = [];

try {
    const response = await fetch('https://dev.to/api/articles?username=altaskur&per_page=6');
    if (response.ok) {
        const data = await response.json();
        devtoArticles = data.map((a: any) => ({
            title: a.title,
            description: a.description,
            url: a.url,
            published_at: a.published_at,
            tag_list: a.tag_list || [],
            cover_image: a.cover_image || null,
            source: 'devto' as const,
        }));
    }
} catch (e) {
    console.warn('[BlogSection] Dev.to API unavailable at build time');
}

const allArticles = [...localArticles, ...devtoArticles]
    .sort((a, b) => new Date(b.published_at).valueOf() - new Date(a.published_at).valueOf())
    .slice(0, 3);
---

<section id="blog" class="px-4 py-20 md:px-10">
    <div class="mb-16 flex items-end justify-between">
        <h2 class="blog-header text-3xl font-bold text-white md:text-4xl opacity-0 translate-y-8">
            <span class="text-accent">05.</span> El blog
        </h2>
        <a href="/blog"
           class="hidden font-mono text-sm text-gray-500 hover:text-accent transition-colors md:block">
            /// ver todos →
        </a>
    </div>

    <div class="space-y-16 md:space-y-32">
        {allArticles.map((article, index) => {
            const isLocal = article.source === 'local';
            const isExternal = !isLocal;
            const extAttrs = isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {};
            return (
                <article class="lab-card relative grid gap-10 md:grid-cols-2 items-center opacity-0 translate-y-20">
                    <div class={`space-y-6 ${index % 2 === 1 ? 'md:order-2' : ''}`}>
                        <div class="flex items-center gap-4 text-accent font-mono text-sm">
                            <span>0{index + 1}</span>
                            <span class="h-px w-10 bg-accent"></span>
                            <span>{article.tag_list.slice(0, 3).join(' / ')}</span>
                        </div>

                        <a href={article.url} {...extAttrs} class="block group/title">
                            <h3 class="text-2xl font-bold text-white md:text-3xl lg:text-4xl group-hover/title:text-accent transition-colors">
                                {article.title}
                            </h3>
                        </a>

                        <p class="text-lg text-gray-400">{article.description}</p>

                        <div class="flex items-center gap-4 pt-4 flex-wrap">
                            {isLocal ? (
                                <span class="inline-flex items-center gap-1.5 font-mono text-xs font-bold px-2.5 py-1 rounded-md bg-accent/10 text-accent border border-accent/30">
                                    <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
                                    altaskur.dev
                                </span>
                            ) : (
                                <span class="inline-flex items-center gap-1.5 font-mono text-xs font-bold px-2.5 py-1 rounded-md bg-indigo-500/10 text-indigo-400 border border-indigo-500/30">
                                    <span class="w-1.5 h-1.5 rounded-full bg-indigo-400"></span>
                                    dev.to
                                </span>
                            )}

                            <a href={article.url} {...extAttrs} class="text-sm font-bold text-white hover:text-accent transition-colors flex items-center gap-2">
                                Leer articulo
                                {isExternal ? (
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
                                ) : (
                                    <span aria-hidden="true">-></span>
                                )}
                            </a>

                            <span class="text-sm font-mono text-gray-400">
                                {new Date(article.published_at).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}
                            </span>
                        </div>
                    </div>

                    <a
                        href={article.url}
                        {...extAttrs}
                        class={`relative aspect-video overflow-hidden rounded-lg bg-gray-900 border border-gray-800 group block ${index % 2 === 1 ? 'md:order-1' : ''}`}
                    >
                        {isLocal ? (
                            <span class="absolute top-3 right-3 z-10 inline-flex items-center gap-1.5 font-mono text-[10px] font-bold px-2 py-1 rounded bg-accent/15 text-accent border border-accent/30 backdrop-blur-sm">
                                <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
                                altaskur.dev
                            </span>
                        ) : (
                            <span class="absolute top-3 right-3 z-10 inline-flex items-center gap-1.5 font-mono text-[10px] font-bold px-2 py-1 rounded bg-indigo-500/15 text-indigo-400 border border-indigo-500/30 backdrop-blur-sm">
                                <span class="w-1.5 h-1.5 rounded-full bg-indigo-400"></span>
                                dev.to
                            </span>
                        )}

                        {article.cover_image ? (
                            <img
                                src={isLocal ? article.cover_image : getProxyImage(article.cover_image)}
                                alt={article.title}
                                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                loading="lazy"
                            />
                        ) : (
                            <div
                                class="absolute inset-0 flex items-center justify-center"
                                style={isLocal ? 'background:#0a1500' : 'background:#0a0a0a'}
                            >
                                <div class="transform group-hover:scale-110 transition-transform duration-300">
                                    {isLocal ? (
                                        <span class="font-mono text-accent/40 text-xs">altaskur.dev</span>
                                    ) : (
                                        <span class="font-mono text-indigo-400/40 text-xs">dev.to</span>
                                    )}
                                </div>
                            </div>
                        )}
                        <div class="absolute inset-0 bg-accent/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    </a>
                </article>
            );
        })}
    </div>

    <div class="mt-16 md:mt-24 flex justify-center">
        <a
            href="/blog"
            class="group inline-flex items-center gap-3 font-mono text-sm font-bold text-white bg-accent/10 border border-accent/40 px-8 py-4 rounded-xl hover:bg-accent hover:text-black hover:border-accent transition-all duration-300"
        >
            <span class="text-accent group-hover:text-black transition-colors">$</span>
            ver todos los artículos
            <span class="translate-x-0 group-hover:translate-x-1 transition-transform duration-300">→</span>
        </a>
    </div>
</section>

<script>
import { gsap } from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";

gsap.registerPlugin(ScrollTrigger);

const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

gsap.to(".blog-header", {
    opacity: 1,
    y: 0,
    duration: prefersReducedMotion ? 0 : 0.8,
    ease: "power2.out",
    scrollTrigger: {
        trigger: "#blog",
        start: "top 80%",
    }
});

gsap.utils.toArray<HTMLElement>(".lab-card").forEach((card) => {
    gsap.to(card, {
        opacity: 1,
        y: 0,
        duration: prefersReducedMotion ? 0 : 0.9,
        ease: "power2.out",
        scrollTrigger: {
            trigger: card,
            start: "top 85%",
        }
    });
});
</script>
