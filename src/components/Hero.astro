---
---

<section id="hero" class="relative flex min-h-screen flex-col justify-center overflow-hidden px-4 py-20 md:px-10">
	<div class="z-10 w-full max-w-4xl">

		<p class="hero-text-anim font-mono text-sm text-accent tracking-widest mb-4">
			Isaac Julián Pavón Ruiz · altaskur
		</p>

		<h1 class="text-4xl font-bold tracking-tight text-white md:text-6xl lg:text-7xl leading-tight">
			<span class="hero-text-anim inline-block">Software</span>
			<span class="hero-text-anim inline-block text-accent">Developer</span>
			<br class="hidden md:block" />
			<span class="hero-text-anim inline-block">Angular</span>
			<span class="hero-text-anim inline-block"><span class="text-gray-500">·</span> TypeScript</span>
			<span class="hero-text-anim inline-block"><span class="text-gray-500">·</span> a11y</span>
		</h1>

		<p class="mt-6 text-lg text-gray-300 font-light leading-relaxed hero-text-anim-secondary max-w-2xl">
			Dos años llevando aplicaciones Angular a producción en entornos enterprise, trabajando con versiones 18 a 21 con SSR.
			Accesibilidad web (WCAG 2.1/2.2) e IA aplicada como parte estable del flujo, no como extras.
		</p>

		<div class="mt-8 hero-text-anim-secondary border-l-2 border-accent/30 pl-6 space-y-2">
			<span class="block text-sm font-mono text-gray-500">
				<span class="text-accent">></span> LOC: Elda, Alicante, ES &nbsp;·&nbsp; remoto preferente
			</span>
			<span class="block text-sm font-mono text-gray-500">
				<span class="text-accent">></span> Ponente DevFest Alicante 2025 &nbsp;·&nbsp; abierto a nuevas oportunidades
			</span>
		</div>

		<!-- CTAs -->
		<div class="mt-10 flex flex-wrap gap-4 hero-text-anim-secondary">
			<a
				href="#dashboard"
				class="group relative inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 text-sm font-mono font-bold text-black transition-all hover:bg-accent/90 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-gray-950"
			>
				Ver proyectos
			</a>
			<a
				href="#social"
				class="group inline-flex items-center gap-2 rounded-lg border border-gray-700 bg-gray-800/50 px-6 py-3 text-sm font-mono text-gray-300 transition-all hover:border-accent hover:text-white focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-gray-950"
			>
				Contactar
			</a>
		</div>

	</div>

	<!-- Scroll Indicator -->
	<div class="absolute bottom-10 left-1/2 -translate-x-1/2 text-center hero-text-anim-secondary">
		<span class="block text-xs font-mono text-gray-400">
			↓ Explorar
		</span>
	</div>

	<!-- Playground Panel (oculto, accesible por atajo de teclado) -->
	<div id="playground-panel" class="fixed right-4 top-20 z-50 hidden w-64 rounded-xl border border-gray-800 bg-gray-900/90 p-4 shadow-2xl backdrop-blur-md">
		<h2 class="mb-4 text-xs font-mono font-bold uppercase tracking-wider text-gray-500">System Controls</h2>
		<div class="space-y-4">
			<div>
				<label class="mb-2 block text-xs text-gray-400">Accent Color</label>
				<div class="flex gap-2">
					<button class="h-6 w-6 rounded-full bg-blue-500 ring-2 ring-transparent ring-offset-2 ring-offset-gray-900 transition-all hover:ring-white color-btn" data-color="#3B82F6" aria-label="Color azul"></button>
					<button class="h-6 w-6 rounded-full bg-emerald-500 ring-2 ring-transparent ring-offset-2 ring-offset-gray-900 transition-all hover:ring-white color-btn" data-color="#10B981" aria-label="Color verde"></button>
					<button class="h-6 w-6 rounded-full bg-purple-500 ring-2 ring-transparent ring-offset-2 ring-offset-gray-900 transition-all hover:ring-white color-btn" data-color="#8B5CF6" aria-label="Color morado"></button>
					<button class="h-6 w-6 rounded-full bg-orange-500 ring-2 ring-transparent ring-offset-2 ring-offset-gray-900 transition-all hover:ring-white color-btn" data-color="#F97316" aria-label="Color naranja"></button>
				</div>
			</div>
			<div>
				<label class="mb-2 block text-xs text-gray-400">Grid Intensity</label>
				<input type="range" min="0" max="0.5" step="0.05" value="0.2" class="w-full h-1 bg-gray-800 rounded-lg appearance-none cursor-pointer accent-accent" id="grid-intensity" aria-label="Intensidad de la cuadrícula">
			</div>
		</div>
	</div>

	<!-- Floating Action Button (AI Terminal) -->
	<button
		id="fab-ai-trigger"
		class="fixed bottom-6 right-6 z-[90] flex h-14 w-14 items-center justify-center rounded-full bg-accent text-black shadow-lg shadow-accent/20 transition-all hover:scale-110 hover:shadow-accent/40 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-900 group"
		aria-label="Abrir terminal IA"
	>
		<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:rotate-12" aria-hidden="true">
			<polyline points="4 17 10 11 4 5"></polyline>
			<line x1="12" y1="19" x2="20" y2="19"></line>
		</svg>
		<span class="absolute -top-1 -right-1 h-3 w-3 motion-safe:animate-ping rounded-full bg-white opacity-75" style="animation-iteration-count:3" aria-hidden="true"></span>
		<span class="absolute -top-1 -right-1 h-3 w-3 rounded-full bg-white" aria-hidden="true"></span>
	</button>
</section>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (!prefersReducedMotion) {
		// Scroll-triggered fade out
		const textElements = document.querySelectorAll(".hero-text-anim");
		const secondaryText = document.querySelectorAll(".hero-text-anim-secondary");

		const scrollTl = gsap.timeline({
			scrollTrigger: {
				trigger: "#hero",
				start: "top top",
				end: "bottom center",
				scrub: 1,
			}
		});

		scrollTl.to(textElements, {
			opacity: 0,
			y: -30,
			stagger: 0.1,
			ease: "power1.in"
		});

		scrollTl.to(secondaryText, {
			opacity: 0,
			y: -30,
			duration: 0.5,
			ease: "power1.in"
		}, "<0.5");

		// FAB entrance
		gsap.from("#fab-ai-trigger", {
			scale: 0,
			opacity: 0,
			duration: 0.5,
			delay: 0.5,
			ease: "back.out(1.7)"
		});
	}

	// AI Terminal trigger
	const triggerAI = () => {
		if (typeof (window as any).openAITerminal === 'function') {
			(window as any).openAITerminal();
		}
	};

	document.getElementById('fab-ai-trigger')?.addEventListener('click', triggerAI);
</script>
