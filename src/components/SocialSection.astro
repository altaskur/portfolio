---

<section id="social" class="relative py-20 overflow-hidden">
    <div class="relative z-10 px-4 md:px-10">
        <div class="mb-16 social-header text-center">
            <h2 class="text-3xl font-bold text-white md:text-4xl mb-4"><span class="text-accent">07.</span> Social</h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6 max-w-4xl mx-auto">
            {socials.map((social, index) => (
                <a
                    href={social.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${social.name}: ${social.username}`}
                    class="social-card group relative p-6 rounded-2xl border border-gray-800/50 bg-gray-900/30 backdrop-blur-sm hover:border-accent/50 transition-all duration-300 hover:scale-105 hover:bg-gray-900/50 focus:outline-none focus:ring-2 focus:ring-accent"
                    style={`--card-color: ${social.color}; animation-delay: ${index * 0.1}s`}
                >
                    <div class="flex flex-col items-center text-center gap-3">
                        <div class="text-gray-400 group-hover:text-[var(--card-color)] transition-colors duration-300" set:html={social.icon}></div>
                        <div>
                            <h3 class="text-lg font-bold text-white group-hover:text-accent transition-colors">{social.name}</h3>
                            <p class="text-xs font-mono text-gray-400 mt-1">{social.username}</p>
                        </div>
                    </div>
                    <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" style={`box-shadow: 0 0 40px ${social.color}20, inset 0 0 20px ${social.color}10`}></div>
                </a>
            ))}
        </div>

        <!-- CTA disponibilidad -->
        <div class="mt-12 text-center availability-cta opacity-0 translate-y-5">
            <a
                href="https://www.linkedin.com/in/isaac-julián/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 rounded-full border border-accent/30 bg-accent/10 px-6 py-3 transition-all hover:border-accent hover:bg-accent/20 focus:outline-none focus:ring-2 focus:ring-accent"
            >
                <span class="h-2 w-2 motion-safe:animate-pulse rounded-full bg-accent"></span>
                <span class="font-mono text-sm text-accent">Abierto a ofertas · 100% remoto</span>
                <span class="font-mono text-xs text-gray-500">→ LinkedIn</span>
            </a>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const initSocialAnimations = () => {
        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (prefersReducedMotion) return;

        const header = document.querySelector(".social-header");
        const cards = document.querySelectorAll(".social-card");

        if (header) {
            gsap.set(header, { opacity: 0, y: 30 });
            gsap.to(header, {
                opacity: 1,
                y: 0,
                duration: 0.6,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: "#social",
                    start: "top 80%",
                    toggleActions: "play none none reverse"
                }
            });
        }

        if (cards.length > 0) {
            gsap.set(cards, { opacity: 0, y: 40, scale: 0.9 });
            gsap.to(cards, {
                opacity: 1,
                y: 0,
                scale: 1,
                duration: 0.5,
                stagger: 0.08,
                ease: "back.out(1.7)",
                scrollTrigger: {
                    trigger: "#social",
                    start: "top 70%",
                    toggleActions: "play none none reverse"
                }
            });
        }
        // CTA disponibilidad
        const cta = document.querySelector(".availability-cta");
        if (cta) {
            gsap.to(cta, {
                opacity: 1, y: 0,
                duration: 0.6,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: cta,
                    start: "top 90%",
                    end: "top 10%",
                    toggleActions: "play reverse play reverse"
                }
            });
        }
    };

    document.addEventListener("astro:page-load", initSocialAnimations);
    document.addEventListener("DOMContentLoaded", initSocialAnimations);

    if (document.readyState === "complete" || document.readyState === "interactive") {
        setTimeout(initSocialAnimations, 200);
    }
</script>
