---
import AnimatedBackground from './AnimatedBackground.astro';
---

<div id="boot-screen" class="fixed inset-0 z-[999] flex flex-col items-start justify-end bg-black p-10 font-mono text-sm text-gray-400 font-bold overflow-hidden">
    <div class="absolute inset-0 z-0">
        <AnimatedBackground />
    </div>
    <div class="relative z-10">
        <div id="boot-text" class="whitespace-pre-wrap"></div>
        <div class="mt-2 text-accent animate-pulse" aria-hidden="true">_</div>
    </div>
</div>

<script>
    import { gsap } from "gsap";

    const bootLines = [
        "INITIALIZING DARK SYSTEMS PROTOCOL...",
        "LOADING KERNEL MODULES: [GSAP, LENIS, TAILWIND]",
        "ESTABLISHING SECURE CONNECTION...",
        "LOC: ALICANTE, ES",
        "USER: ALTASKUR",
        "STATUS: ONLINE",
        "BOOT SEQUENCE COMPLETE."
    ];

    const bootScreen = document.getElementById("boot-screen");
    const textContainer = document.getElementById("boot-text");
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (prefersReducedMotion) {
        if (bootScreen) bootScreen.style.display = "none";
    } else {
        const exitBootScreen = () => {
            if (!bootScreen) return;
            gsap.to(bootScreen, {
                yPercent: -100,
                duration: 0.8,
                ease: "power4.inOut",
                delay: 0.2,
                onComplete: () => {
                    bootScreen.style.display = "none";
                }
            });
        };

        const tl = gsap.timeline({ onComplete: exitBootScreen });

        // Use tl.to() with duration so the timeline has real tweens to sequence —
        // tl.call()-only timelines with "+=" offsets can stall in Vite/HMR environments.
        bootLines.forEach((line, i) => {
            tl.to({}, {
                duration: 0.15,
                onStart: () => {
                    if (!textContainer) return;
                    const div = document.createElement("div");
                    div.className = i > 4 ? "text-accent mb-1" : "text-green-500 mb-1";
                    div.innerText = "> " + line;
                    textContainer.appendChild(div);
                }
            });
        });

        tl.to({}, { duration: 0.5 });

        // Safety fallback: if the timeline fails for any reason, force-exit after a timeout
        const safetyMs = (bootLines.length * 0.15 + 0.5 + 1.5) * 1000;
        setTimeout(() => {
            if (bootScreen && bootScreen.style.display !== "none") {
                tl.kill();
                exitBootScreen();
            }
        }, safetyMs);
    }
</script>
