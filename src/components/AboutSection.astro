---
import { skills, aboutParagraphs } from "../data/site";
---

<section id="about" class="px-4 py-20 md:px-10" aria-labelledby="about-heading">

    <div class="mb-16 flex items-end justify-between about-header opacity-0 translate-y-10">
        <h2 id="about-heading" class="text-3xl font-bold text-white md:text-5xl">
            <span class="text-accent">02.</span> Sobre mí
        </h2>
        <span class="hidden font-mono text-sm text-gray-500 md:block">/// WHO I AM</span>
    </div>

    <div class="grid gap-16 md:grid-cols-2">

        <div class="about-col space-y-6 text-gray-400 leading-relaxed">
            {aboutParagraphs.map(p => (
                <p class="about-item opacity-0 translate-y-10">{p}</p>
            ))}
        </div>

        <div class="about-col space-y-8">

            <div class="about-item opacity-0 translate-y-10">
                <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-3">Frontend</p>
                <div class="flex flex-wrap gap-2">
                    {skills.frontend.map(tag => (
                        <span class="rounded border border-gray-700 bg-gray-900 px-3 py-1 text-xs font-mono text-gray-300">{tag}</span>
                    ))}
                </div>
            </div>

            <div class="about-item opacity-0 translate-y-10">
                <p class="text-xs font-mono text-accent uppercase tracking-widest mb-3">Accesibilidad</p>
                <div class="flex flex-wrap gap-2">
                    {skills.a11y.map(tag => (
                        <span class="rounded border border-accent/30 bg-accent/5 px-3 py-1 text-xs font-mono text-accent/80">{tag}</span>
                    ))}
                </div>
            </div>

            <div class="about-item opacity-0 translate-y-10">
                <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-3">IA aplicada</p>
                <div class="flex flex-wrap gap-2">
                    {skills.ia.map(tag => (
                        <span class="rounded border border-gray-700 bg-gray-900 px-3 py-1 text-xs font-mono text-gray-300">{tag}</span>
                    ))}
                </div>
            </div>

            <div class="about-item opacity-0 translate-y-10">
                <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-3">Backend</p>
                <div class="flex flex-wrap gap-2">
                    {skills.backend.map(tag => (
                        <span class="rounded border border-gray-700 bg-gray-900 px-3 py-1 text-xs font-mono text-gray-300">{tag}</span>
                    ))}
                </div>
            </div>

            <div class="about-item opacity-0 translate-y-10">
                <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-3">Tooling</p>
                <div class="flex flex-wrap gap-2">
                    {skills.tooling.map(tag => (
                        <span class="rounded border border-gray-700 bg-gray-900 px-3 py-1 text-xs font-mono text-gray-300">{tag}</span>
                    ))}
                </div>
            </div>

            <div class="about-item opacity-0 translate-y-10">
                <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-3">Trabajando con</p>
                <div class="flex flex-wrap gap-2">
                    {skills.explorando.map(tag => (
                        <span class="rounded border border-gray-800 bg-gray-900/50 px-3 py-1 text-xs font-mono text-gray-500">{tag}</span>
                    ))}
                </div>
            </div>

        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const initAboutAnimations = () => {
        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (prefersReducedMotion) {
            document.querySelectorAll(".about-header, .about-item").forEach(el => {
                (el as HTMLElement).style.opacity = "1";
                (el as HTMLElement).style.transform = "none";
            });
            return;
        }

        gsap.to(".about-header", {
            y: 0,
            opacity: 1,
            duration: 0.8,
            ease: "power3.out",
            scrollTrigger: {
                trigger: "#about",
                start: "top 80%",
                toggleActions: "play none none reverse"
            }
        });

        document.querySelectorAll(".about-item").forEach((el) => {
            gsap.to(el, {
                y: 0,
                opacity: 1,
                duration: 1,
                ease: "power3.out",
                scrollTrigger: {
                    trigger: el,
                    start: "top 82%",
                    toggleActions: "play none none reverse"
                }
            });
        });
    };

    document.addEventListener("astro:page-load", initAboutAnimations);
    document.addEventListener("DOMContentLoaded", initAboutAnimations);

    if (document.readyState === "complete" || document.readyState === "interactive") {
        setTimeout(initAboutAnimations, 100);
    }
</script>
