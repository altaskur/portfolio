---
const stackProfesional = ["Angular 18–21", "TypeScript", "JavaScript", "HTML5", "CSS3 / SCSS", "PrimeNG", "Ionic", "Astro", "SSR"];
const stackA11y = ["WCAG 2.1 / 2.2", "Lighthouse", "WAVE", "IBM Equal Access", "ARIA", "i18n"];
const stackIA = ["Claude Code", "GitHub Copilot", "Ollama"];
const stackBackend = ["Node.js", "Express"];
const stackTooling = ["Storybook", "ESLint", "Prettier", "Husky", "CommitLint", "Stylelint", "SonarQube", "Azure DevOps", "GitHub Actions"];
const stackPersonal = ["React", "Vue", "LLMs locales"];
---

<section id="about" class="px-4 py-20 md:px-10" aria-labelledby="about-heading">

    <div class="mb-16 flex items-end justify-between about-header opacity-0 translate-y-10">
        <h2 id="about-heading" class="text-3xl font-bold text-white md:text-5xl">
            <span class="text-accent">02.</span> Sobre mí
        </h2>
        <span class="hidden font-mono text-sm text-gray-500 md:block">/// WHO I AM</span>
    </div>

    <div class="grid gap-16 md:grid-cols-2">

        <div class="about-col space-y-6 text-gray-400 leading-relaxed opacity-0 translate-y-10">
            <p>
                Soy Software Developer con dos años de experiencia en una consultora tecnológica,
                llevando aplicaciones Angular a producción en proyectos de largo recorrido.
                He trabajado con Angular 18, 19, 20 y 21 a lo largo de distintas fases y productos —
                lo que me da una visión real de cómo evoluciona un ecosistema, no solo una foto fija.
            </p>
            <p>
                La accesibilidad web y la IA aplicada no son cosas que añado al final;
                forman parte de cómo construyo desde el principio.
            </p>
            <p>
                Fuera del trabajo: escribo en Dev.to sobre lo que aprendo, programo en directo
                en Twitch y hablo en eventos como el <strong class="text-gray-300 font-medium">DevFest Alicante 2025</strong>,
                donde copresenté la charla <em>«Accesibilidad en dos tiempos»</em>.
            </p>
            <p class="font-mono text-sm text-gray-600">
                <span class="text-accent">></span> Disponible para oportunidades 100% remoto
            </p>
        </div>

        <div class="about-col space-y-8 opacity-0 translate-y-10">

            <div>
                <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-3">Profesional</p>
                <div class="flex flex-wrap gap-2">
                    {stackProfesional.map(tag => (
                        <span class="rounded border border-gray-700 bg-gray-900 px-3 py-1 text-xs font-mono text-gray-300">{tag}</span>
                    ))}
                </div>
            </div>

            <div>
                <p class="text-xs font-mono text-accent uppercase tracking-widest mb-3">Accesibilidad</p>
                <div class="flex flex-wrap gap-2">
                    {stackA11y.map(tag => (
                        <span class="rounded border border-accent/30 bg-accent/5 px-3 py-1 text-xs font-mono text-accent/80">{tag}</span>
                    ))}
                </div>
            </div>

            <div>
                <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-3">IA aplicada</p>
                <div class="flex flex-wrap gap-2">
                    {stackIA.map(tag => (
                        <span class="rounded border border-gray-700 bg-gray-900 px-3 py-1 text-xs font-mono text-gray-300">{tag}</span>
                    ))}
                </div>
            </div>

            <div>
                <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-3">Backend</p>
                <div class="flex flex-wrap gap-2">
                    {stackBackend.map(tag => (
                        <span class="rounded border border-gray-700 bg-gray-900 px-3 py-1 text-xs font-mono text-gray-300">{tag}</span>
                    ))}
                </div>
            </div>

            <div>
                <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-3">Tooling y DevOps</p>
                <div class="flex flex-wrap gap-2">
                    {stackTooling.map(tag => (
                        <span class="rounded border border-gray-700 bg-gray-900 px-3 py-1 text-xs font-mono text-gray-300">{tag}</span>
                    ))}
                </div>
            </div>

            <div>
                <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-2">Exploración personal</p>
                <p class="text-[10px] font-mono text-gray-700 mb-3">// fuera del stack profesional</p>
                <div class="flex flex-wrap gap-2">
                    {stackPersonal.map(tag => (
                        <span class="rounded border border-gray-800 bg-gray-900/50 px-3 py-1 text-xs font-mono text-gray-500">{tag}</span>
                    ))}
                </div>
            </div>

        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const initAboutAnimations = () => {
        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (prefersReducedMotion) {
            document.querySelectorAll(".about-header, .about-col").forEach(el => {
                (el as HTMLElement).style.opacity = "1";
                (el as HTMLElement).style.transform = "none";
            });
            return;
        }

        gsap.to(".about-header", {
            y: 0,
            opacity: 1,
            duration: 0.8,
            ease: "power3.out",
            scrollTrigger: {
                trigger: "#about",
                start: "top 80%",
                end: "top 15%",
                toggleActions: "play reverse play reverse"
            }
        });

        document.querySelectorAll(".about-col").forEach((col, i) => {
            gsap.to(col, {
                y: 0,
                opacity: 1,
                duration: 1,
                delay: i * 0.15,
                ease: "power3.out",
                scrollTrigger: {
                    trigger: col,
                    start: "top 80%",
                    end: "top 10%",
                    toggleActions: "play reverse play reverse"
                }
            });
        });
    };

    document.addEventListener("astro:page-load", initAboutAnimations);
    document.addEventListener("DOMContentLoaded", initAboutAnimations);

    if (document.readyState === "complete" || document.readyState === "interactive") {
        setTimeout(initAboutAnimations, 100);
    }
</script>
